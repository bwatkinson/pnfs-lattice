#!/usr/bin/env bash
# shellcheck shell=bash
#
# Default inventory for scripts/pnfs-lab.
# This file intentionally contains topology and role data only.
# Keep SSH passwords out of git:
#
#   export PNFS_LAB_SSH_PASSWORD='...'
#
# The target user must have passwordless sudo on every lab host.
#

LAB_USER="peak"
LAB_SSH_OPTS=(
    -o StrictHostKeyChecking=no
    -o ConnectTimeout=5
)

LAB_SOURCE_DIR="/home/warp/code/pnfs-mds"
LAB_BUILD_DIR="/home/warp/code/pnfs-mds/build"
LAB_BUILD_TYPE="Release"

LAB_BUILD_HOST_RONDB_BASE="${HOME}/.cache/pnfs-mds/rondb"
LAB_BUILD_HOST_RONDB_LINK="${LAB_BUILD_HOST_RONDB_BASE}/current"

LAB_REMOTE_RONDB_VERSION="24.10.19"
LAB_REMOTE_RONDB_TARBALL_URL="https://repo.hops.works/master/rondb-${LAB_REMOTE_RONDB_VERSION}-linux-glibc2.28-x86_64.tar.gz"
LAB_REMOTE_RONDB_BASE="/opt/pnfs-mds-lab"
LAB_REMOTE_RONDB_LINK="/opt/rondb"

LAB_RONDB_SCHEMA_NAME="pnfs_mds"
LAB_RONDB_MGM_HOST="192.168.100.55"
LAB_RONDB_MGM_IP="10.10.10.55"
LAB_RONDB_MGM_NODE_ID="65"
LAB_RONDB_MGM_PORT="1186"
LAB_RONDB_DATA_DIR="/var/lib/rondb"
LAB_RONDB_DATA_MEMORY="2G"

LAB_MDS_NFS_PORT="2049"
LAB_MDS_GRPC_PORT="50051"
LAB_MDS_CONF_DIR="/etc/pnfs-mds"
LAB_MDS_RUN_DIR="/var/lib/pnfs-mds"
LAB_MDS_DS_MOUNT_FMT="/mnt/ds%u"

LAB_DS_HOSTS=(
    "192.168.100.52"
    "192.168.100.53"
    "192.168.100.56"
    "192.168.100.57"
)
LAB_DS_IPS=(
    "10.10.10.52"
    "10.10.10.53"
    "10.10.10.56"
    "10.10.10.57"
)
LAB_DS_IDS=(
    "0"
    "1"
    "2"
    "3"
)
LAB_DS_EXPORTS=(
    "/export/ds"
    "/export/ds"
    "/export/ds"
    "/export/ds"
)
LAB_DS_EXPORT_SUBNET="10.10.10.0/24"
LAB_DS_EXPORT_OPTIONS="rw,sync,no_subtree_check,no_root_squash,insecure"

# TCP parallelism on the MDS->DS NFS mounts.  Every MDS worker that
# touches a DS file (proxy write, layout pre-create, LAYOUTCOMMIT
# size extension, GC unlink) serialises on the kernel mount's TCP
# sockets, so nconnect=1 bottlenecks parallel creates even when the
# client side is fanned out.  Match the client nconnect by default.
# Set to 1 to force a single socket for debugging.
LAB_DS_NCONNECT="8"

# knfsd server-side thread pool.  Ubuntu ships with threads=8 by
# default, which is the serialisation floor when multiple MDS daemons
# each open nconnect=N sockets to the same DS.  Bump to something
# generous enough to absorb the product of (cluster MDS count) x
# (worker_threads) x (DS mount nconnect).  32 comfortably covers the
# multi-mds lab (3 MDS x 8 workers = 24 parallel writers per DS).
LAB_DS_NFSD_THREADS="32"

LAB_CLIENT_HOST="192.168.100.54"
LAB_CLIENT_IP="10.10.10.54"
LAB_CLIENT_MOUNT="/mnt/pnfs"
LAB_CLIENT_NCONNECT="8"

LAB_PROFILE_DEFAULT="single-mds"

# Single-MDS lab:
#   - mds1 on .50
#   - RonDB data node colocated on .50
#   - RonDB mgm on .55
LAB_PROFILE_SINGLE_MDS_HOSTS=(
    "192.168.100.50"
)
LAB_PROFILE_SINGLE_MDS_IPS=(
    "10.10.10.50"
)
LAB_PROFILE_SINGLE_MDS_IDS=(
    "1"
)
LAB_PROFILE_SINGLE_RONDB_DATA_HOSTS=(
    "192.168.100.50"
)
LAB_PROFILE_SINGLE_RONDB_DATA_IPS=(
    "10.10.10.50"
)
LAB_PROFILE_SINGLE_RONDB_DATA_NODE_IDS=(
    "1"
)
LAB_PROFILE_SINGLE_RONDB_NUM_REPLICAS="1"
LAB_PROFILE_SINGLE_RONDB_FREE_API_SLOTS="8"
LAB_PROFILE_SINGLE_MDS_WORKER_THREADS="8"
LAB_PROFILE_SINGLE_MDS_PREALLOC_POOL_SIZE="4096"
LAB_PROFILE_SINGLE_TRANSIENT_STATE_CACHE="true"

# Multi-MDS RonDB lab:
#   - mds1 on .50
#   - mds2 on .51
#   - mds3 on .55 (shares the host with the RonDB mgm service)
#   - RonDB data nodes on .50 and .51
LAB_PROFILE_MULTI_MDS_HOSTS=(
    "192.168.100.50"
    "192.168.100.51"
    "192.168.100.55"
)
LAB_PROFILE_MULTI_MDS_IPS=(
    "10.10.10.50"
    "10.10.10.51"
    "10.10.10.55"
)
LAB_PROFILE_MULTI_MDS_IDS=(
    "1"
    "2"
    "3"
)
LAB_PROFILE_MULTI_RONDB_DATA_HOSTS=(
    "192.168.100.50"
    "192.168.100.51"
)
LAB_PROFILE_MULTI_RONDB_DATA_IPS=(
    "10.10.10.50"
    "10.10.10.51"
)
LAB_PROFILE_MULTI_RONDB_DATA_NODE_IDS=(
    "1"
    "2"
)
LAB_PROFILE_MULTI_RONDB_NUM_REPLICAS="2"
LAB_PROFILE_MULTI_RONDB_FREE_API_SLOTS="16"
LAB_PROFILE_MULTI_MDS_WORKER_THREADS="8"
LAB_PROFILE_MULTI_MDS_PREALLOC_POOL_SIZE="4096"
LAB_PROFILE_MULTI_TRANSIENT_STATE_CACHE="true"
