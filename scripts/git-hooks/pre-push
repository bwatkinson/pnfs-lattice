#!/bin/bash
# pre-push — Refuse pushes to pnfs-ng that carry Warp artefacts.
#
# Belt-and-braces to the filter-repo rewrite in scripts/sync-to-ng.sh:
# if anyone ever adds `ng` as a remote on the working clone and
# pushes directly, this hook rejects the push before any bytes hit
# the wire.
#
# Install once per clone with:
#   ln -sf ../../scripts/git-hooks/pre-push .git/hooks/pre-push
#
# git invokes pre-push with:
#   $1 = remote name (e.g. "ng")
#   $2 = remote URL
# and feeds one line per pushed ref on stdin:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
# We inspect the commit range and scan for forbidden paths.

set -euo pipefail

REMOTE_NAME="${1:-}"
REMOTE_URL="${2:-}"

# Only enforce when the target is the pnfs-ng mirror.  Other remotes
# (origin, peakaio) legitimately carry these files.
case "${REMOTE_NAME}" in
    ng|pnfs-ng) ;;
    *)
        case "${REMOTE_URL}" in
            *pnfs-ng*) ;;
            *) exit 0 ;;
        esac
        ;;
esac

FORBIDDEN=(
    '^\.warp/'
    '^\.warp$'
    '^AGENTS\.md$'
    '^scripts/sync-to-ng\.sh$'
    '^scripts/git-hooks/'
)

ZERO='0000000000000000000000000000000000000000'
fail=0

while read -r local_ref local_sha remote_ref remote_sha; do
    # Skip deletions.
    if [ "${local_sha}" = "${ZERO}" ]; then
        continue
    fi

    # New branch on remote: scan everything reachable from local_sha
    # that isn't already on another branch.  --not --remotes=ng
    # keeps the scan bounded to the branch we're creating.
    if [ "${remote_sha}" = "${ZERO}" ]; then
        range="${local_sha} --not --remotes=${REMOTE_NAME}"
    else
        range="${remote_sha}..${local_sha}"
    fi

    # shellcheck disable=SC2086  # range intentionally word-splits.
    files="$(git log --name-only --pretty=format: ${range} 2>/dev/null | sort -u)"

    for pat in "${FORBIDDEN[@]}"; do
        hit="$(printf '%s\n' "${files}" | grep -E "${pat}" || true)"
        if [ -n "${hit}" ]; then
            printf 'pre-push: refusing to push to %s — forbidden path(s):\n' "${REMOTE_NAME}" >&2
            printf '  %s\n' ${hit} >&2
            fail=1
        fi
    done
done

if [ "${fail}" -ne 0 ]; then
    printf 'pre-push: use scripts/sync-to-ng.sh to mirror main to pnfs-ng.\n' >&2
    exit 1
fi

exit 0
